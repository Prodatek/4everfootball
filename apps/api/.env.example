S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="fourever"
S3_SECRET_ACCESS_KEY="fourever123"
S3_BUCKET="media"
S3_PUBLIC_URL="http://localhost:9000/media"

MEILISEARCH_HOST="http://localhost:7700"
